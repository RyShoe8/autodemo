# ─────────────────────────────────────────────────────────────────────────────
# AutoDemo AI — Environment Variables
# Copy this file to `.env` and fill in the values. The app + worker share it.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (required for real persistence).
# If omitted, the app/worker run in an in-memory fallback mode (data is not durable).
MONGODB_URI=

# OpenAI API key. If omitted, workflow/script/TTS steps use deterministic mocks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Single internal admin password used for login. REQUIRED in production.
# If omitted in development, a default of "autodemo" is used.
ADMIN_PASSWORD=

# Secret used to sign the auth session cookie (any long random string).
# If omitted, a development-only default is used. Set a strong value in production.
AUTH_SECRET=

# 32-byte key (hex or base64 or any string) used to encrypt stored login passwords.
# If omitted, a development-only default is used. Set a strong value in production.
ENCRYPTION_KEY=

# ElevenLabs API key (optional). Only needed when a project uses the ElevenLabs voice.
ELEVENLABS_API_KEY=

# Vercel Blob token. Required when STORAGE_DRIVER=blob.
BLOB_READ_WRITE_TOKEN=

# Storage driver: "local" (default, writes to ./storage) or "blob" (Vercel Blob).
STORAGE_DRIVER=local

# Blob access mode: "private" (Vercel default) or "public". Must match your store.
BLOB_ACCESS=private

# Worker poll interval in milliseconds (how often the worker checks for jobs).
WORKER_POLL_INTERVAL=3000

# Remotion render tuning (worker only). Omit REMOTION_CONCURRENCY on 1-vCPU Render;
# set to 2–4 only on multi-vCPU workers.
# REMOTION_CONCURRENCY=2
# REMOTION_TIMEOUT_MS=120000
# REMOTION_OFFTHREAD_CACHE_MB=256
# FFMPEG_SLICE_CONCURRENCY=1

# Public base URL of the app (used by the worker to build absolute asset URLs).
APP_BASE_URL=http://localhost:3000
